generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  profile        UserProfile?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mdaId     String?  // References MDA, can be null if admin
  mda       MDA?     @relation(fields: [mdaId], references: [id], onDelete: SetNull)
  fullName  String
  role      Role     @default(MDA_OFFICER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MDA {
  id        String        @id @default(uuid())
  name      String
  code      String?
  profiles  UserProfile[]
  projects  Project[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Project {
  projectId          String           @id @default(uuid()) @map("project_id")
  mdaId              String           @map("mda_id")
  mda                MDA              @relation(fields: [mdaId], references: [id])
  title              String
  sector             String
  lga                String
  senatorialDistrict String           @map("senatorial_district")
  locationText       String           @map("location_text")
  startDate          DateTime         @map("start_date")
  endDate            DateTime         @map("end_date")
  approvedBudget     Decimal          @map("approved_budget") @db.Decimal(15, 2)
  fundingSource      String           @map("funding_source")
  contractor         String?
  status             String
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt
  
  progressUpdates    ProgressUpdate[]
  financeRecords     FinanceRecord[]
  issues             Issue[]

  @@map("projects")
}

model ProgressUpdate {
  id                  String   @id @default(uuid())
  projectId           String   @map("project_id")
  project             Project  @relation(fields: [projectId], references: [projectId])
  reportDate          DateTime @map("report_date")
  physicalProgressPct Float    @map("physical_progress_pct")
  stage               String
  milestoneStatus     String   @map("milestone_status")
  keyUpdate           String   @db.Text @map("key_update")
  issueFlag           String?  @map("issue_flag")
  evidenceLink        String?  @map("evidence_link")
  status              ReportStatus @default(DRAFT)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt
  issues              Issue[]

  @@map("progress_updates")
}

model FinanceRecord {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  project        Project  @relation(fields: [projectId], references: [projectId])
  budgetYear     Int      @map("budget_year")
  releaseToDate  Decimal  @map("release_to_date") @db.Decimal(15, 2)
  paymentsToDate Decimal  @map("payments_to_date") @db.Decimal(15, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("finance")
}

model Issue {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  project       Project  @relation(fields: [projectId], references: [projectId])
  logDate       DateTime @map("log_date")
  issueCategory String   @map("issue_category")
  issueItem     String   @map("issue_item")
  severity      Int
  owner         String
  dueDate       DateTime @map("due_date")
  status        String   @default("Open")
  notes         String   @db.Text
  followUp            String?  @db.Text @map("follow_up")
  progressUpdateId    String?  @map("progress_update_id")
  progressUpdate      ProgressUpdate? @relation(fields: [progressUpdateId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("issues")
}

enum Role {
  WEBMASTER_ADMIN
  PPIMU_ADMIN
  MDA_OFFICER
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}
